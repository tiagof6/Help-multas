{
  "expo": {
    "name": "Help Multas",
    "slug": "help-multas",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "experiments": {
      "baseUrl": "/Help-multas"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.tiagof6.helpmultas",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "./withAndroidQueries.js",
      [
        "expo-av",
        {
          "microphonePermission": "O aplicativo precisa acessar o microfone para gravar áudios de abordagem."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "861703c3-9e3d-452d-b34e-e727bf2ed857"
      }
    }
  }
}